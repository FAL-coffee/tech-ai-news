# Postgres接続文字列(ローカルDocker / Supabase / Neon)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tech_ai_news

# LLM
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
CLASSIFY_MODEL=claude-haiku-4-5
GENERATE_MODEL=claude-sonnet-5
EMBEDDING_MODEL=text-embedding-3-small

# パイプライン制御
IMPORTANCE_THRESHOLD=60
CLASSIFY_BATCH_SIZE=50
MAX_GENERATE_PER_RUN=10

# 自動実行スケジューラ(apps/apiプロセスが起動している間、一定間隔でcollect→classify→generateを実行)
# デフォルトは無効。有効化するとLLM API課金が定期的に発生する点に注意。
SCHEDULER_ENABLED=false
SCHEDULER_RUN_ON_START=false
COLLECT_INTERVAL_MINUTES=30

# apps/api
PORT=8787

# 認証(better-auth) — BETTER_AUTH_SECRETはランダムな32バイト以上の文字列にすること
# 生成例: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# /admin (収集先候補・タグ候補の承認画面)へのアクセスを許可するメールアドレス(カンマ区切り)
ADMIN_EMAILS=you@example.com

# 課金(Stripe) — 値はStripeダッシュボード(ユーザー自身のアカウント)で取得する
# STRIPE_PRICE_ID は `pnpm stripe:setup` で自動作成することも可能
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
TRIAL_PERIOD_DAYS=14
